# 配置文件模板
# 复制此文件为 .env 并填入实际值

# GitHub Token for Gist API
GITHUB_TOKEN=your_github_token_here

# Bark 推送通知设备密钥
BARK_DEVICE_KEY=your_bark_device_key_here

# GitHub Gist ID for URL storage
GIST_ID=your_gist_id_here

# Bilibili 用户 UID
BILIBILI_UID=your_bilibili_uid_here

# Bark 推送通知应用标题
BARK_APP_TITLE=your_app_title_here
